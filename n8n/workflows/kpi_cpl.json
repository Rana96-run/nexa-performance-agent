                  },
                  {
                      "id":  "6f112bda-44c1-5c98-8d36-cb12aa07943f",
                      "name":  "Parse Claude",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1000,
                                       0
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "\nconst raw=$json.content?.find(b=\u003eb.type===\u0027text\u0027)?.text||\u0027{}\u0027;\nconst ch=$(\u0027Trigger\u0027).first().json.channel, t=new Date().toISOString().slice(0,10);\ntry{\n  const r=JSON.parse(raw);\n  return [{json:{\n    task_name: r.asana_title||`[CPL FIX] ${ch} - CPL above threshold`,\n    task_notes:`Channel: ${ch}\\n\\nRoot Cause:\\n${r.root_cause||\u0027See data\u0027}\\n\\nWorst Adsets:\\n${(r.worst_adsets||[]).map(a=\u003e`. ${a.adset_name}: $${a.cpl} - ${a.recommendation}`).join(\u0027\\n\u0027)}\\n\\nRecommendation:\\n${r.channel_recommendation||\u0027-\u0027}\\n\\nCreated: ${t} | Due: +2d | Priority: P1 | Type: CPL Fix | Channel: ${ch} | Asset level: Ad Set | Action: optimize ? [campaign-manager]`,\n    due_on: new Date(Date.now()+2*86400000).toISOString().slice(0,10)\n  }}];\n}catch(e){return [{json:{task_name:`CPL Fix parse error`,task_notes:raw,due_on:t}}];}\n"
                                     }
                  },
