                                                                                         "value":  "2023-06-01"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ model:\u0027claude-sonnet-4-6\u0027, max_tokens:2000, system:$json.system, messages:$json.messages }) }}",
                                         "options":  {

