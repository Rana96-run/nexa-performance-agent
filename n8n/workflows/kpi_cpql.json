                      "id":  "349c7321-8441-5bbe-b5fa-b4319f011948",
                      "name":  "BQ - CPQL Drill",
                      "type":  "n8n-nodes-base.googleBigQuery",
                      "typeVersion":  2,
                      "position":  [
                                       250,
                                       0
                                   ],
                      "credentials":  {
                                          "googleApi":  {
                                                            "id":  "kE5RxM61mQkpV21N",
                                                            "name":  "BigQuery (Qoyod)"
                                                        }
                                      },
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "projectId":  "angular-axle-492812-q4",
                                         "sqlQuery":  "WITH hs AS (\n  SELECT date, LOWER(lead_utm_campaign) AS campaign_key,\n         SUM(leads_total) AS leads_total,\n         SUM(leads_qualified) AS leads_qualified\n  FROM `angular-axle-492812-q4.qoyod_marketing.hubspot_leads_module_daily`\n  WHERE date \u003e= DATE_SUB(CURRENT_DATE(\u0027Asia/Riyadh\u0027), INTERVAL 30 DAY)\n  GROUP BY date, LOWER(lead_utm_campaign)\n)\nSELECT c.date, c.channel, c.campaign_name, c.campaign_id,\n       SUM(c.spend) AS spend,\n       SUM(hs.leads_total) AS leads_total,\n       SUM(hs.leads_qualified) AS leads_qualified,\n       SAFE_DIVIDE(SUM(c.spend), SUM(hs.leads_total)) AS cpl,\n       SAFE_DIVIDE(SUM(c.spend), SUM(hs.leads_qualified)) AS cpql\nFROM `angular-axle-492812-q4.qoyod_marketing.campaigns_daily` c\nLEFT JOIN hs ON c.date = hs.date\n           AND LOWER(c.campaign_name) = hs.campaign_key\nWHERE c.date \u003e= DATE_SUB(CURRENT_DATE(\u0027Asia/Riyadh\u0027), INTERVAL 30 DAY)\n  AND c.spend \u003e 0\nGROUP BY c.date, c.channel, c.campaign_name, c.campaign_id\nORDER BY cpql DESC NULLS LAST\nLIMIT 30",
                                         "authentication":  "serviceAccount",
                                         "options":  {

                                                     }
                                     }
                  },
                  {
                      "id":  "7ba4b3b9-2ce4-516a-82f0-01269d3d907d",
                      "name":  "Build Claude Prompt",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       500,
                                       0
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const rows=$input.all().map(i=\u003ei.json);\nconst ch=$(\u0027Trigger\u0027).first().json.channel, cpql=$(\u0027Trigger\u0027).first().json.cpql;\n\n// CPQL zones (USD): scale \u003c$85 | acceptable $80-$95 | warning $95-$130 | pause \u003e$160\n// CPL zones (USD): scale \u003c$25 | acceptable $25-$38 | warning $40-$49 | pause \u003e$50\nconst zoneLabel = cpql \u003c 85 ? \u0027SCALE (\u003c $85)\u0027\n  : cpql \u003c= 95  ? \u0027ACCEPTABLE ($80-$95)\u0027\n  : cpql \u003c= 130 ? \u0027WARNING ($95-$130)\u0027\n  : \u0027PAUSE ZONE (\u003e $160)\u0027;\n\nconst worst = rows.filter(r =\u003e (r.cpql||0) \u003e 95).slice(0, 8);\n\nconst systemPrompt = `You are a paid media analyst for Qoyod (Arabic SaaS - B2B accounting). Analyze CPQL data for ${ch}.\n\nCPQL ZONES (USD - source: hubspot_leads_module_daily, NOT platform conversions):\n- Scale: \u003c $85\n- Acceptable: $80-$95\n- Warning: $95-$130\n- PAUSE required: \u003e $160\n\nCPL ZONES (USD):\n- Scale: \u003c $25\n- Acceptable: $25-$38\n- Warning: $40-$49\n- PAUSE required: \u003e $50\n\nDATA SOURCE RULES (non-negotiable):\n- CPQL = SUM(campaigns_daily.spend) / SUM(hubspot_leads_module_daily.leads_qualified) via CTE join\n- NEVER use platform-reported conversion counts for CPQL or CPL\n- Lead source: hubspot_leads_module_daily ONLY (hubspot_leads_daily is legacy - ignore it)\n- CTE join key: LOWER(campaign_name) = LOWER(lead_utm_campaign)\n- Pre-aggregate HubSpot in a CTE before joining to avoid spend fan-out\n\nAWARENESS GATE:\n- Campaigns with objective WebsiteTraffic / ImpressionShare / Reach: SKIP CPQL/CPL checks entirely\n- For awareness campaigns: evaluate Search Impression Share (IS%) only\n\nMINIMUM DATA WINDOW:\n- Require \u003e= 14 days of data before recommending pause or scale action\n- Fewer than 14 days = monitoring flag only - state \"insufficient data\" and do NOT recommend action\n\nENTRY GATE:\n- CPQL \u003e $95 (warning zone): flag and investigate root cause\n- CPQL \u003e $160 (pause zone): audit immediately, recommend pause via #approvals\n\nSEED AUDIENCE REBUILD (when recommending audience change):\n- Use HubSpot deal/lead association filters: Closed Won or Qualified stage deals only\n- NEVER reference contact-level product interest properties - they have 0% fill rate and are empty\n- Audience pauses require performance-lead approval via #approvals before execution\n\nCRO HANDOFF CHAIN (when CPQL traced to LP quality issue):\n- CRO Specialist ? UI/UX Designer ? Developer ? pixel verification ? LP sign-off\n- Pixel verification: BOTH Meta pixels must be observed firing on form submit\n- UTM passthrough: confirmed on hidden form fields before sign-off\n- LP sign-off only after both pixel firing AND UTM passthrough are confirmed\n\nKEYWORD CLEANUP (after pausing free/discount copy creatives):\n- Run keyword audit for matching search terms: ?????, ?????, ??????, free, discount\n- Add as ALWAYS_NEGATIVE in BOTH Arabic AND English - bilingual mandatory\n- Both scripts (Arabic + Latin) must be checked and negated\n\nAPPROVAL RULE (non-negotiable):\n- ALL budget cuts, campaign pauses, and audience changes must go to #approvals channel first\n- Wait for user ? reaction before any execution - ? skips\n- This sub-flow outputs RECOMMENDATIONS ONLY - it never auto-executes pauses or budget changes\n\nOutput valid JSON only:\n{\"root_cause\":string,\"zone\":string,\"worst_campaigns\":[{\"campaign_name\":string,\"cpql\":number,\"leads_qualified\":number,\"data_window_days\":number,\"recommendation\":string}],\"channel_recommendation\":string,\"requires_approval\":true,\"asana_title\":string}`;\n\nreturn [{json:{\n  system: systemPrompt,\n  messages:[{role:\u0027user\u0027,content:`Channel: ${ch}\\nCurrent CPQL: $${cpql} (${zoneLabel})\\n\\nCampaign breakdown (last 30 days, HubSpot CTE-joined):\\n${JSON.stringify(worst,null,2)}`}]\n}}];"
                                     }
                  },
                  {
