# Copy to .env and fill in. Never commit the real .env.
# For GitHub Actions, paste each value into repo Settings > Secrets and Variables.

# ----- Anthropic -----
ANTHROPIC_API_KEY=

# ----- Google Ads -----
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_IDS=

# ----- Google / BigQuery -----
GOOGLE_APPLICATION_CREDENTIALS=./bigquery-key.json
BQ_PROJECT_ID=
BQ_DATASET=
BQ_LOCATION=

# ----- Meta -----
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_1=
META_AD_ACCOUNT_2=

# ----- HubSpot -----
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PORTAL_ID=

# ----- Slack (dual channel) -----
SLACK_ACCESS_TOKEN=
SLACK_CHANNEL_NOTIFY=
SLACK_CHANNEL_APPROVAL=

# ----- Asana -----
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_PROJECT_DAILY_ACTIVITY=
ASANA_PROJECT_OPTIMIZATION=
ASANA_PROJECT_CAMPAIGNS_HUB=
ASANA_PROJECT_SEASONAL=

# ----- Email (SMTP) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Qoyod Performance Agent
EMAIL_ALL=
EMAIL_TEAM_LEAD=
EMAIL_TEAM_MANAGER=
EMAIL_PERFORMANCE=

# ----- Miro -----
MIRO_ACCESS_TOKEN=
MIRO_BOARD_ID=

# ----- Agent behavior -----
# 'email' (default while Slack is set up) | 'slack' | 'both'
NOTIFY_VIA=email
