# ── HubSpot (REQUIRED) ───────────────────────────────────────────────────────
# Private-app token from HubSpot → Settings → Integrations → Private Apps.
# READ-ONLY in this agent — no PATCH/DELETE/POST without Amar's Slack sign-off.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PORTAL_ID=


# ── Slack (REQUIRED) ─────────────────────────────────────────────────────────
# Bot token (xoxb-…) and signing secret from api.slack.com → Your Apps.
# Channel IDs (not names) — copy from channel URL or /slack_info command.
SLACK_BOT_TOKEN=
SLACK_ACCESS_TOKEN=
SLACK_REFRESH_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=          # primary daily-report channel
SLACK_CHANNEL_NOTIFY=      # #data-health alerts (ID: C0ARMQKK8GK)
SLACK_CHANNEL_APPROVAL=    # #approvals channel for pause/scale gate
SLACK_CHANNEL_HEALTH=      # connector health alerts


# ── Anthropic / Claude (REQUIRED) ────────────────────────────────────────────
# API key from console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=


# ── Asana (REQUIRED) ─────────────────────────────────────────────────────────
