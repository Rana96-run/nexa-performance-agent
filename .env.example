# GIDs confirmed 2026-06-09 via API.
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_ASSIGNEE_GID=        # default fallback assignee GID

# Named-person GIDs — do not change without re-confirming via Asana API
ASANA_ASSIGNEE_RANA=1208007704598388
ASANA_ASSIGNEE_DONIA=1211896896006195
ASANA_ASSIGNEE_THELMY=1211659245827014

# Per-role overrides — set in Railway/GitHub Secrets to reassign without a code deploy
ASANA_ASSIGNEE_ORCHESTRATOR=
ASANA_ASSIGNEE_PERFORMANCE_LEAD=
ASANA_ASSIGNEE_CAMPAIGN_MANAGER=
ASANA_ASSIGNEE_MARKETING_OPS=
ASANA_ASSIGNEE_GROWTH_ANALYST=
ASANA_ASSIGNEE_CREATIVE=
ASANA_ASSIGNEE_CRO=
ASANA_ASSIGNEE_UIUX=
ASANA_ASSIGNEE_DEVELOPER=
ASANA_ASSIGNEE_DEVELOPER_CO=

# Portfolio and project GIDs
ASANA_PORTFOLIO_OPTIMIZATION=
ASANA_PORTFOLIO_DAILY_ACTIVITY=
ASANA_PORTFOLIO_SEASONAL=
ASANA_PROJECT_DAILY_ACTIVITY=
ASANA_PROJECT_OPTIMIZATION=
ASANA_PROJECT_CAMPAIGNS_HUB=
ASANA_PROJECT_SEASONAL=
ASANA_PROJECT_CRO=1215576593439221     # CRO & Landing Pages (created 2026-06-09)


# ── Email / SMTP (optional) ───────────────────────────────────────────────────
# Gmail SMTP relay. Reserved for future Slack-to-email digest switch — keep
# even if unused so enabling the feature requires no Railway redeployment.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
EMAIL_TEAM_LEAD=
EMAIL_TEAM_MANAGER=
EMAIL_PERFORMANCE=
EMAIL_ALL=


# ── GA4 (optional) ───────────────────────────────────────────────────────────
# Property ID from Google Analytics 4 → Admin → Property Settings.
GA4_PROPERTY_ID=

# Google Search Console
# Site URL as registered in GSC (sc-domain: prefix for domain property).
GSC_SITE_URL=sc-domain:qoyod.com


# ── Databox (optional) ───────────────────────────────────────────────────────
# Push API token from app.databox.com → Data Sources → Custom → Push Custom Data.
DATABOX_TOKEN=


# ── Hex dashboards (optional) ────────────────────────────────────────────────
# API token from hex.tech → Settings → API.
# HEX_PERFORMANCE_PROJECT_ID: UUID of the main performance Hex project.
HEX_API_TOKEN=
HEX_PERFORMANCE_PROJECT_ID=
DASHBOARD_URL=
ACTIVITY_DASHBOARD_URL=       # /activity endpoint — sole activity dashboard (Hex Activity removed 2026-06-21)
DASHBOARD_DEST_URL=


# ── n8n Cloud (REQUIRED) ─────────────────────────────────────────────────────
# JWT from n8n Cloud → Settings → API → Create API Key.
# Used by the agent to trigger Master (T8icImtZFLYeCa7e) and Data Collection
# (jOnJxdpdaO3Vbi0B) workflows.
N8N_API_KEY=


# ── Miro (optional) ──────────────────────────────────────────────────────────
# Powers miro_agent_workflow.py — auto-updates the Miro board after architecture
# changes. OAuth credentials from the Miro Developer app (developer.miro.com).
MIRO_ACCESS_TOKEN=
MIRO_BOARD_ID=
MIRO_CLIENT_ID=
MIRO_CLIENT_SECRET=
MIRO_REDIRECT_URI=


# ── Google Drive (optional) ──────────────────────────────────────────────────
# Folder IDs from Drive URLs: drive.google.com/drive/folders/<ID>
# Root folder is already known; create subfolders inside it and paste IDs below.
GDRIVE_FOLDER_ID=1yI0-3TirRuVAxKIKrq2aR-9gVB2UdT74   # root — shared team folder
GDRIVE_REPORTS_FOLDER_ID=            # subfolder: Nexa Performance Reports/Monthly Decks
GDRIVE_CREATIVE_REPORTS_FOLDER_ID=   # subfolder: Nexa Performance Reports/Creative Reports


# ── Agent runtime config ──────────────────────────────────────────────────────
# APP_DOMAIN: public hostname of the Railway deployment (no trailing slash).
# NOTIFY_VIA: notification channel — "slack" is the only supported value.
# NEXA_QUIET: set to "true" to suppress non-critical Slack messages locally.
# DATA_DIR: scratch directory for temporary collector output files.
APP_DOMAIN=
NOTIFY_VIA=slack
NEXA_QUIET=false
DATA_DIR=/tmp
