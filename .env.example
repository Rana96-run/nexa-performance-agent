# ─────────────────────────────────────────────────────────────────────────────
#  Nexa Performance Agent — environment template
#
#  HOW TO USE
#  1. Copy this file to `.env` (gitignored):  cp .env.example .env
#  2. Fill in credentials in `.env`.  Never commit `.env`.
#  3. Push secrets to Railway:        railway variables set KEY=value
#  4. Local runs inject Railway vars:  railway run python <script.py>
#
#  OWNERSHIP
#  Use your own account credentials where a system supports individual logins
#  (e.g. Microsoft Ads, LinkedIn) so that actions are attributable.
#
#  RUNTIME
#  - Live collectors run on GitHub Actions (.github/workflows/collectors.yml).
#    Secrets there → repo Settings → Secrets and variables → Actions.
#  - Railway hosts the operational agent (main.py / reporting_scheduler.py).
#    Railway is the source of truth for runtime env vars.
#  - When rotating a credential: update local .env → GitHub Secrets → Railway.
# ─────────────────────────────────────────────────────────────────────────────


# ── BigQuery & Google credentials (REQUIRED) ─────────────────────────────────
# Service-account key from GCP console → IAM → Service Accounts → Keys.
# Local: path to secrets/bigquery-key.json (file is gitignored).
# Railway/GitHub Actions: paste the full JSON blob into the _JSON var instead.
GOOGLE_APPLICATION_CREDENTIALS=        # local only: path to secrets/bigquery-key.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=   # Railway/GH Actions: full service-account JSON blob

# BigQuery project, dataset, and write region.
BQ_PROJECT_ID=
BQ_DATASET=
BQ_LOCATION=


# ── WordPress / qoyod.com (REQUIRED) ──────────────────────────────────────
# Use YOUR OWN WordPress user + Application Password — NOT a shared login.
# Every page/post the agent creates or edits is authored by this account, so
# WordPress itself records your name on each change.
# Create an App Password: WP Admin → Users → (you) → Application Passwords.
WP_BASE_URL="https://lp.qoyod.com"
WP_USERNAME="your.wordpress.username"
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"



# ── Semrush (Standard API — 2M units/mo: reporting + keyword research) ─────
# Powers tools/semrush_client.py + the weekly Position-Tracking report.
SEMRUSH_API_KEY=""
SEMRUSH_DATABASE="sa"            # regional database for Analytics calls (Saudi)
SEMRUSH_TARGET_DOMAIN="lp.qoyod.com"


# ── Google Ads (REQUIRED) ─────────────────────────────────────────────────────
# Developer token: Google Ads UI → Tools → API Centre.
# OAuth credentials: GCP Console → APIs → Credentials → OAuth 2.0 Client.
# GOOGLE_ADS_CUSTOMER_IDS: comma-separated MCC sub-account IDs (no hyphens).
# GOOGLE_ADS_CUSTOMER_ID: legacy single-account fallback — keep in sync.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_IDS=          # comma-separated MCC sub-accounts
GOOGLE_ADS_CUSTOMER_ID=           # legacy single-account fallback


# ── Meta (REQUIRED) ──────────────────────────────────────────────────────────
# System user token from Meta Business Suite → Users → System Users.
# META_AD_ACCOUNT_1 / _2: act_XXXXXXXXXX format.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_1=
META_AD_ACCOUNT_2=
META_APP_ID=
META_APP_SECRET=
META_FB_PAGE_ID=
META_IG_BUSINESS_ID=
META_PAGE_ACCESS_TOKEN=
META_USER_TOKEN_SHORT=


# ── TikTok (REQUIRED) ────────────────────────────────────────────────────────
# OAuth app credentials from TikTok for Business → Developer Portal.
# TIKTOK_AD_ACCOUNT_2024 / _2025: separate accounts per contract year.
# TIKTOK_PIXEL_2024 / TIKTOK_CRM_PIXEL: pixel IDs from TikTok Events Manager.
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_AD_ACCOUNT_2024=
TIKTOK_AD_ACCOUNT_2025=
TIKTOK_PIXEL_2024=
TIKTOK_CRM_PIXEL=


# ── Snapchat (REQUIRED) ──────────────────────────────────────────────────────
# OAuth app credentials from Snapchat Business → Developer Portal.
# SNAPCHAT_CAPI_TOKEN: Conversions API token from Events Manager.
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=
SNAPCHAT_ACCESS_TOKEN=
SNAPCHAT_REFRESH_TOKEN=
SNAPCHAT_CAPI_TOKEN=
SNAPCHAT_AD_ACCOUNT_2024=
SNAPCHAT_AD_ACCOUNT_2025=
SNAPCHAT_PIXEL=


# ── LinkedIn (REQUIRED) ──────────────────────────────────────────────────────
# OAuth app credentials from LinkedIn Developer Portal.
# LI_ORGANIZATION_URN: urn:li:organization:XXXXXXXX
# LI_AD_ACCOUNT_URN:   urn:li:sponsoredAccount:XXXXXXXX
# Use rana.khalid@qoyod.com credentials so ad actions are attributable.
LI_CLIENT_ID=
LI_CLIENT_SECRET=
LI_REDIRECT_URI=
LI_ACCESS_TOKEN=
LI_REFRESH_TOKEN=
LI_ORGANIZATION_URN=
LI_AD_ACCOUNT_URN=
LI_BUSINESS_MANAGER_ID=


# ── Microsoft Ads (REQUIRED) ─────────────────────────────────────────────────
# Account 1: rana.khalid@qoyod.com
