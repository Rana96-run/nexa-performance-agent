MS_DEVELOPER_TOKEN=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_CLIENT_SECRET_ID=
MS_OBJECT_ID=
MS_TENANT_ID=
MS_APP_NAME=
MS_REDIRECT_URI=
MS_ACCOUNT_ID=
MS_ACCOUNT_NUMBER=
