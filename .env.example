# ── X Ads (optional) ─────────────────────────────────────────────────────────
# OAuth 1.0a credentials from developer.twitter.com → Projects → Keys.
X_ADS_CONSUMER_KEY=
X_ADS_CONSUMER_SECRET=
X_ADS_ACCESS_TOKEN=
