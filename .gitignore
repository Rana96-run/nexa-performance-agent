# ── Secrets / credentials — NEVER commit ──────────────────────────────────
.env
.env.*
!.env.example
certs/
bigquery-key.json
*.json.key
*service-account*.json
*credentials*.json
*.pem

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Editors / OS ─────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
.DS_Store
Thumbs.db

# ── Runtime output ────────────────────────────────────────────────────────
logs/*.log
*.log

# ── Local data / cache ────────────────────────────────────────────────────
data/
.cache/
cache/*.json
scripts/miro_dump.json
memory/_drive_index.json

# ── Generated report HTML — never commit (always regenerated nightly) ─────
reports/*.html

# ── Generated screenshot PNGs (uploaded to Miro, not source-of-truth) ─────
scripts/_screenshots/

# ── Build artifacts ───────────────────────────────────────────────────────
dist/
build/

# ── Misc ──────────────────────────────────────────────────────────────────
*.bak
*~
