# ── Secrets / credentials — NEVER commit ──────────────────────────────────
.env
.env.*
!.env.example
certs/
bigquery-key.json
*.json.key
*service-account*.json
*credentials*.json
*.pem

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Editors / OS ─────────────────────────────────────────────────────────
.vscode/
.idea/
# .claude/ is mostly per-user (settings.json has user-specific permissions),
# but we SHARE the hooks folder + an example settings template so all
# team agents enforce the same KPI rules.
.claude/*
!.claude/hooks/
!.claude/settings.example.json
!.claude/skills/
!.claude/agents/
!.claude/workflows/
*.swp
.DS_Store
Thumbs.db

# ── Runtime output ────────────────────────────────────────────────────────
logs/*.log
*.log

# ── Local data / cache ────────────────────────────────────────────────────
data/
.cache/
cache/*.json
scripts/miro_dump.json
memory/_drive_index.json

# ── Generated report HTML — never commit (always regenerated nightly) ─────
reports/*.html

# ── Generated screenshot PNGs (uploaded to Miro, not source-of-truth) ─────
scripts/_screenshots/

# ── Build artifacts ───────────────────────────────────────────────────────
dist/
build/

# ── Misc ──────────────────────────────────────────────────────────────────
*.bak
*~
_ms_new_token.tmp
_ms_rt2_set.bat

# Ad-hoc debug dumps from one-off scripts (project root)
asana_debug.txt
asana_fields.txt
asana_fields_check.txt
asana_opts.txt
asana_progress.txt

# ── One-off probe / debug scripts (underscore prefix = temp, not production) ──
scripts/_*.py
scripts/_*.txt
scripts/_*.json
scripts/_*_sheet/
scripts/_semrush_zatca/

# ── Skills Building Reference (source material, not deployed code) ─────────
Skills Building Ref/
